# Normalizes a Frappe/clone JSON response so two equivalent responses diff to
# nothing. Erases volatile fields (autogenerated names, timestamps, users,
# hashes) that legitimately differ between the two systems, recursively.
#
# Usage: jq -S -f normalize.jq  (the -S sorts object keys for stable diffs)

def scrub:
  if type == "object" then
    with_entries(
      # Replace values of volatile keys with a stable placeholder.
      if (.key | ascii_downcase) as $k
         | ["name","creation","modified","modified_by","owner","idx",
            "_user_tags","_comments","_assign","_liked_by"]
         | index($k)
      then .value = "<NORM>"
      else .value |= scrub
      end
    )
  elif type == "array" then map(scrub)
  else .
  end;

scrub
